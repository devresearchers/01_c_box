#!/bin/bash
set -euo pipefail

if [ "${DISABLE_FIREWALL:-false}" = "true" ]; then
    rm -f "$0"
    exit 0
fi

iptables -F OUTPUT 2>/dev/null || true
iptables -F INPUT 2>/dev/null || true

# Basic allow rules
iptables -A OUTPUT -p udp --dport 53 -j ACCEPT
iptables -A OUTPUT -p tcp --dport 53 -j ACCEPT
iptables -A INPUT -p udp --sport 53 -j ACCEPT
iptables -A OUTPUT -o lo -j ACCEPT
iptables -A INPUT -i lo -j ACCEPT
iptables -A OUTPUT -s 127.0.0.0/8 -d 127.0.0.0/8 -j ACCEPT
iptables -A INPUT -s 127.0.0.0/8 -d 127.0.0.0/8 -j ACCEPT
iptables -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

DENYLIST_FILE="/home/DOCKERUSER/.claudebox/denylist"
LOG_CHAIN="CLAUDEBOX_DENY"

iptables -N "$LOG_CHAIN" 2>/dev/null || true

DENY_DOMAINS=""
if [ -f "$DENYLIST_FILE" ]; then
    while IFS= read -r line; do
        [[ "$line" =~ ^#.* ]] && continue
        [[ -z "$line" ]] && continue
        domain="${line#*.}"
        domain="$(echo "$domain" | xargs)"
        [[ -n "$domain" ]] && DENY_DOMAINS="$DENY_DOMAINS $domain"
    done < "$DENYLIST_FILE"
fi

if command -v ipset >/dev/null 2>&1; then
    ipset destroy deny-domains 2>/dev/null || true
    ipset create deny-domains hash:net
    for domain in $DENY_DOMAINS; do
        if [[ "$domain" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?$ ]]; then
            ipset add deny-domains "$domain" 2>/dev/null || true
        else
            ips=$(getent hosts "$domain" 2>/dev/null | awk '{print $1}')
            for ip in $ips; do
                ipset add deny-domains "$ip" 2>/dev/null || true
            done
        fi
    done
    iptables -A "$LOG_CHAIN" -m set --match-set deny-domains dst -j LOG --log-prefix "FIREWALL_DENY: " --log-level info
    iptables -A "$LOG_CHAIN" -m set --match-set deny-domains dst -j DROP
else
    for domain in $DENY_DOMAINS; do
        if [[ "$domain" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?$ ]]; then
            iptables -A "$LOG_CHAIN" -d "$domain" -j LOG --log-prefix "FIREWALL_DENY:$domain " --log-level info
            iptables -A "$LOG_CHAIN" -d "$domain" -j DROP
        else
            ips=$(getent hosts "$domain" 2>/dev/null | awk '{print $1}')
            for ip in $ips; do
                iptables -A "$LOG_CHAIN" -d "$ip" -j LOG --log-prefix "FIREWALL_DENY:$domain " --log-level info
                iptables -A "$LOG_CHAIN" -d "$ip" -j DROP
            done
        fi
    done
fi

iptables -A OUTPUT -j "$LOG_CHAIN"

iptables -P OUTPUT ACCEPT
iptables -P INPUT ACCEPT

rm -f "$(realpath "$0")"
